datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ninios    Ninio[]  @relation("UserNinios")
  cuidadorOf CuidadorNinio[] @relation("CuidadorUser")
}

model Ninio {
  id          String   @id @default(uuid())
  fullName    String
  weight      Float
  height      Float
  age         Int
  diagnosticos String[]
  rescueMed        String?
  rescueDose       String?
  alertMinutes     Int?
  ambulanceMinutes Int?
  emergencyPhone   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trackers    Tracker[]
  crisis      Crisis[]
  userId      String?
  user        User?        @relation("UserNinios", fields: [userId], references: [id], onDelete: Cascade)
  medications  Medicacion[]
  consultas    Consulta[]
  shareToken   String?  @unique
  cuidadores   CuidadorNinio[] @relation("NinioCuidadores")
}

// permissions JSON shape: { canFillTracker, canSeeHistory, canSeeMeds, canSeeCrisisProtocol }
model CuidadorNinio {
  id          String   @id @default(uuid())
  cuidadorId  String
  cuidador    User     @relation("CuidadorUser", fields: [cuidadorId], references: [id], onDelete: Cascade)
  ninioId     String
  ninio       Ninio    @relation("NinioCuidadores", fields: [ninioId], references: [id], onDelete: Cascade)
  permissions Json
  inviteToken String?  @unique
  inviteEmail String?
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([cuidadorId, ninioId])
}

model Medicacion {
  id        String   @id @default(uuid())
  ninioId   String
  ninio     Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  name            String
  dose            String
  horarios        String
  dias            Int[]
  efectosSubida    String?   // Qué pasa cuando se SUBE la dosis
  efectosBajada    String?   // Qué pasa cuando se BAJA la dosis
  efectosMantenida String?   // Qué pasa cuando se MANTIENE la dosis
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Tracker {
  id        String   @id @default(uuid())
  ninioId   String
  ninio     Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  date      String   

  sleep        Float    
  wakeUps      Int      
  sleepQuality String   
  moods        String[] 
  energy       String   

  hasCrisis      Boolean
  crisisTypes    String[]
  otherType      String?
  crisisSeverity String?   // "leve" | "moderada" | "severa"
  requiredRescue Boolean?  // Requirió medicación de rescate
  requiredER     Boolean?  // Requirió guardia/emergencia
  startTime      String?
  durationHrs    Int?
  durationMin    Int?
  durationSec    Int?
  triggers       String?

  feedQuality   String   
  hasRejection  Boolean
  rejectedMeals String[] 
  mealNote      String?
  bowelCount    Int      
  bristolTypes  String[] 

  tookAllMeds   Boolean
  missedMedIds  String[] 
  doseAltered         Boolean
  alteredMedId        String?
  actualDose          String?
  direccionAlteracion String?
  alteraciones        Json?     // [{medId, dosis, direccion}]
  hadTherapy    Boolean
  therapyTypes  String[]
  therapyDetail String?
  activities    String[]
  attention     String

  intercurrencias     String[]
  intercurrenciasNote String?

  achievements       String?
  hasBehaviorIssue   Boolean
  behaviorDetail     String?
  regulation         String?
  notes              String?
  efectosObservados  String[]
  crises             Json?

  @@unique([ninioId, date])
}

model Consulta {
  id          String   @id @default(uuid())
  ninioId     String
  ninio       Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD
  doctor      String
  specialty   String?
  summary     String
  indications String?
  nextDate    String?  // próxima cita YYYY-MM-DD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Crisis {
  id          String   @id @default(uuid())
  ninioId     String
  ninio       Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  startTime   String   
  endTime     String   
  durationSec Int?
}