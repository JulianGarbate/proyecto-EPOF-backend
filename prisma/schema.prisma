datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

enum Role {
  TUTOR
  CUIDADOR
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(TUTOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ninios    Ninio[]  @relation("UserNinios")
  cuidadorOf CuidadorNinio[] @relation("CuidadorUser")
}

model Ninio {
  id          String   @id @default(uuid())
  fullName    String
  weight      Float
  height      Float
  age         Int
  diagnosticos String[]
  coberturaMedica  String?
  nroAsociado      String?
  terapias         Json?
  doctorName       String?
  doctorPhone      String?
  doctorSpecialty  String?
  rescueMed        String?
  rescueDose       String?
  alertMinutes     Int?
  ambulanceMinutes Int?
  emergencyPhone   String?
  allergies        String?   // alergias conocidas — para la ficha de emergencia
  bowelAlertDays   Int?      // alertar tras N días consecutivos sin evacuar (null = deshabilitado)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  trackers    Tracker[]
  crisis      Crisis[]
  userId      String?
  user        User?        @relation("UserNinios", fields: [userId], references: [id], onDelete: Cascade)
  medications  Medicacion[]
  consultas    Consulta[]
  shareToken     String?  @unique
  emergencyToken String?  @unique
  cuidadores   CuidadorNinio[] @relation("NinioCuidadores")
}

// permissions JSON shape: { canFillTracker, canSeeHistory, canSeeMeds, canSeeCrisisProtocol }
model CuidadorNinio {
  id          String   @id @default(uuid())
  cuidadorId  String
  cuidador    User     @relation("CuidadorUser", fields: [cuidadorId], references: [id], onDelete: Cascade)
  ninioId     String
  ninio       Ninio    @relation("NinioCuidadores", fields: [ninioId], references: [id], onDelete: Cascade)
  permissions Json
  inviteToken String?  @unique
  inviteEmail String?
  accepted    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([cuidadorId, ninioId])
}

model Medicacion {
  id        String   @id @default(uuid())
  ninioId   String
  ninio     Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  name            String
  dose            String
  horarios        String
  dias            Int[]
  efectosSubida    String?   // Qué pasa cuando se SUBE la dosis
  efectosBajada    String?   // Qué pasa cuando se BAJA la dosis
  efectosMantenida String?   // Qué pasa cuando se MANTIENE la dosis
  stockQuantity    Int?      // unidades restantes en stock
  stockUnit        String?   // "comprimidos", "ml", "sobres"...
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Tracker {
  id        String   @id @default(uuid())
  ninioId   String
  ninio     Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  date      String   

  sleep        Float
  sleepNote    String?
  sleepStart   String?   // "HH:MM" — hora en que se durmió (opcional, complementa `sleep`)
  sleepEnd     String?   // "HH:MM" — hora en que se despertó
  naps         Json?     // [{start, end}] — siestas del día
wakeUps      Int
  wakeUpTypes  String[]  // tipos de despertar nocturno (llanto, dolor, sin motivo aparente...)
  sleepQuality String
  moods        String[]
  energy       String

  hasCrisis      Boolean
  crisisTypes    String[]
  otherType      String?
  crisisSeverity String?   // "leve" | "moderada" | "severa"
  requiredRescue Boolean?  // Requirió medicación de rescate
  requiredER     Boolean?  // Requirió guardia/emergencia
  startTime      String?
  durationHrs    Int?
  durationMin    Int?
  durationSec    Int?
  triggers       String?

  feedQuality     String
  hasRejection    Boolean
  rejectedMeals   String[]
  rejectedItems   String?   // qué alimentos rechazó específicamente
  managedToEat    String?   // qué logró comer
  mealNote        String?
  bowelCount    Int      
  bristolTypes  String[] 

  tookAllMeds   Boolean
  missedMedIds  String[] 
  doseAltered         Boolean
  alteredMedId        String?
  actualDose          String?
  direccionAlteracion String?
  alteraciones        Json?     // [{medId, dosis, direccion}]
  hadTherapy    Boolean
  therapyTypes  String[]
  therapyDetail String?
  therapyNotes  Json?     // [{nombre, nota}] — observación por terapia puntual
  activities    String[]
  activitiesOther String?
  activitiesNote  String?   // por qué ocurrió la actividad fuera de lo común
  attention     String
  attentionNote String?   // por qué el nivel de atención fue ese

  hydrationMl   Int?      // ml de agua consumidos en el día

  intercurrencias     String[]
  intercurrenciasNote String?

  achievements          String?
  achievementTime       String?   // "HH:MM" — a qué hora ocurrió el logro
  achievementSpontaneous Boolean? // true = espontáneo, false = hubo estímulo previo
  achievementStimulus   String?   // qué estímulo lo precedió (si no fue espontáneo)
  hasBehaviorIssue   Boolean
  behaviorDetail     String?
  regulation         String?
  notes              String?
  efectosObservados  String[]
  crises             Json?

  @@unique([ninioId, date])
}

model Consulta {
  id          String   @id @default(uuid())
  ninioId     String
  ninio       Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD
  doctor      String
  specialty   String?
  summary     String
  indications String?
  nextDate    String?  // próxima cita YYYY-MM-DD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Crisis {
  id          String   @id @default(uuid())
  ninioId     String
  ninio       Ninio    @relation(fields: [ninioId], references: [id], onDelete: Cascade)
  startTime   String   
  endTime     String   
  durationSec Int?
}