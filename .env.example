# PostgreSQL (Supabase transaction-mode pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"

# PostgreSQL direct (for migrations / Prisma migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT signing secret
JWT_SECRET="your-super-secret-jwt-key"

# Port (Railway/Render use this automatically; Vercel ignores it)
PORT=4000

# Frontend URL for CORS (add your Vercel front URL here)
FRONTEND_URL=https://your-front.vercel.app
